<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.camera.any" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name="com.example.mealcamera.MealCameraApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MealCamera"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true">

        <!-- Yandex Login SDK Meta-data -->
        <meta-data
            android:name="com.yandex.auth.CLIENT_ID"
            android:value="${YANDEX_CLIENT_ID}"
            tools:replace="android:value" />

        <!-- Optional Roboflow credentials -->
        <meta-data
            android:name="com.example.mealcamera.ROBOFLOW_API_KEY"
            android:value="xMdLAXOS8WP8PlXzKZVK" />
        <meta-data
            android:name="com.example.mealcamera.ROBOFLOW_MODEL"
            android:value="splash-qy4gc" />
        <meta-data
            android:name="com.example.mealcamera.ROBOFLOW_VERSION"
            android:value="4" />

        <activity
            android:name="com.example.mealcamera.ui.splash.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.MealCamera">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.mealcamera.ui.auth.WelcomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.example.mealcamera.ui.profile.ProfileEditActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.example.mealcamera.ui.catalog.IngredientCatalogActivity"
            android:exported="false"
            android:label="Выбор ингредиентов"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MealCamera" />

        <activity
            android:name="com.example.mealcamera.ui.auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.example.mealcamera.ui.auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.example.mealcamera.ui.auth.AllergenSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.example.mealcamera.ui.home.MainActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name="com.example.mealcamera.ui.detail.RecipeDetailActivity"
            android:exported="false" />

        <activity
            android:name="com.example.mealcamera.ui.cooking.CookingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>
</manifest>