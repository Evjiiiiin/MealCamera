<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.camera.any" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MealCameraApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MealCamera"
        android:enableOnBackInvokedCallback="true">

        <!-- SplashActivity (Launcher) -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.MealCamera">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Каталог ингредиентов -->
        <activity
            android:name=".ui.catalog.IngredientCatalogActivity"
            android:exported="false"
            android:label="Выбор ингредиентов"
            android:parentActivityName=".ui.scan.ScanActivity"
            android:screenOrientation="portrait" />

        <!-- Аутентификация -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.AllergenSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Главная -->
        <activity
            android:name=".ui.home.MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Сканер -->
        <activity
            android:name=".ui.scan.ScanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.home.MainActivity" />

        <!-- Результаты -->
        <activity
            android:name=".ui.result.ResultActivity"
            android:exported="false"
            android:parentActivityName=".ui.scan.ScanActivity" />

        <!-- Детали рецепта -->
        <activity
            android:name=".ui.detail.RecipeDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.MainActivity" />

        <!-- Готовка -->
        <activity
            android:name=".ui.cooking.CookingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.detail.RecipeDetailActivity" />

        <!-- ДОБАВЛЕНО: Добавление рецепта -->
        <activity
            android:name=".ui.addrecipe.AddRecipeActivity"
            android:exported="false"
            android:parentActivityName=".ui.profile.ProfileFragment"
            android:screenOrientation="portrait" />

    </application>
</manifest>