<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.camera.any" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MealCameraApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MealCamera"
        android:enableOnBackInvokedCallback="true">

        <!-- SplashActivity (Launcher) -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.MealCamera">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Каталог ингредиентов (Оставляем как вспомогательное окно) -->
        <activity
            android:name=".ui.catalog.IngredientCatalogActivity"
            android:exported="false"
            android:label="Выбор ингредиентов"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MealCamera" />

        <!-- Аутентификация -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.AllergenSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ЕДИНСТВЕННАЯ ГЛАВНАЯ ACTIVITY (Single Activity Host) -->
        <activity
            android:name=".ui.home.MainActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustPan" />

        <!-- Детали рецепта -->
        <activity
            android:name=".ui.detail.RecipeDetailActivity"
            android:exported="false" />

        <!-- Готовка -->
        <activity
            android:name=".ui.cooking.CookingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>
</manifest>