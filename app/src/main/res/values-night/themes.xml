<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MealCamera" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorPrimaryContainer">@color/surface_card</item>
        <item name="colorOnPrimaryContainer">@color/text_main</item>
        <item name="android:colorBackground">@color/background_main</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_main</item>
        <item name="colorOutline">@color/border_light</item>
        
        <item name="android:statusBarColor">@color/background_main</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background_main</item>
        <item name="android:windowLightNavigationBar">false</item>

        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        
        <item name="sliderStyle">@style/Widget_MealCamera_Slider</item>
        <item name="chipStyle">@style/Widget_MealCamera_FilterChip</item>
    </style>

    <style name="Widget_MealCamera_BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget_MealCamera_BottomNav_ActiveIndicator</item>
    </style>

    <style name="Widget_MealCamera_BottomNav_ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/color_primary</item>
    </style>

    <style name="Widget_MealCamera_Slider" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/color_primary</item>
        <item name="trackColorActive">@color/color_primary</item>
        <item name="trackColorInactive">@color/surface_card_variant</item>
        <item name="thumbRadius">10dp</item>
        <item name="trackHeight">8dp</item>
        <item name="trackStopIndicatorSize">0dp</item>
        <item name="tickVisible">false</item>
        <item name="labelBehavior">gone</item>
    </style>

    <style name="Widget_MealCamera_FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textColor">@color/text_main</item>
        <item name="chipBackgroundColor">@color/filter_chip_bg_selector</item>
        <item name="chipStrokeColor">@color/filter_chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Medium</item>
    </style>

    <style name="ShapeAppearance.MealCamera.BottomRoundedImage" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>
</resources>