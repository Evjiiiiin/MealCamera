<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MealCamera" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorPrimaryContainer">@color/color_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/color_primary</item>

        <item name="android:colorBackground">@color/background_main</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_main</item>
        <item name="colorOutline">@color/border_light</item>

        <item name="colorSecondaryContainer">@color/color_primary_container</item>
        <item name="colorOnSecondaryContainer">@color/color_primary</item>

        <item name="android:statusBarColor">@color/background_main</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background_main</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="sliderStyle">@style/Widget_MealCamera_Slider</item>
        <item name="chipStyle">@style/Widget_MealCamera_FilterChip</item>
    </style>

    <style name="Widget_MealCamera_BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget_MealCamera_BottomNav_ActiveIndicator</item>
    </style>

    <style name="Widget_MealCamera_BottomNav_ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/color_primary</item>
    </style>

    <style name="Widget_MealCamera_TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/border_light</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/placeholder</item>
        <item name="android:textColorHint">@color/placeholder</item>
    </style>

    <style name="Widget_MealCamera_TextInputLayout_ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/border_light</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">@color/placeholder</item>
        <item name="android:textColorHint">@color/placeholder</item>
    </style>

    <style name="Widget_MealCamera_HeaderLabel" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="Widget_MealCamera_Slider" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/color_primary</item>
        <item name="trackColorActive">@color/color_primary</item>
        <item name="trackColorInactive">@color/color_primary_container</item>
        <item name="thumbRadius">10dp</item>
        <item name="trackHeight">8dp</item>
        <item name="thumbElevation">0dp</item>
        <item name="haloColor">@android:color/transparent</item>
        <item name="trackStopIndicatorSize">0dp</item>
        <item name="tickVisible">false</item>
        <item name="labelBehavior">gone</item>
    </style>

    <style name="Widget_MealCamera_FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textColor">@color/text_main</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/border_light</item>
        <item name="chipBackgroundColor">@color/surface_card</item>
        <item name="checkedIconVisible">false</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Medium</item>
    </style>

    <style name="Widget_MealCamera_Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/color_primary</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget_MealCamera_Button_Outlined" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="strokeColor">@color/color_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="backgroundTint">@color/surface_card</item>
        <item name="rippleColor">@color/color_primary_container</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget_MealCamera_Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="ShapeAppearance.MealCamera.BottomRoundedImage" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>
</resources>